<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A1628">

    <!-- ═══════════════════════════════════════ -->
    <!-- TOP BAR -->
    <!-- ═══════════════════════════════════════ -->

    <!-- Back arrow button — top left -->
    <Button
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:textSize="20sp"
        android:textColor="#FFFFFF"
        android:background="@android:color/transparent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp"
        android:layout_marginStart="8dp"/>

    <!-- Screen title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="LIVE ANALYSIS"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:letterSpacing="0.15"
        app:layout_constraintTop_toTopOf="@id/btnBack"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Share button — top right (Intent: Share) -->
    <Button
        android:id="@+id/btnShare"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:text="Share"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:background="@drawable/btn_outline_bg"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        app:layout_constraintTop_toTopOf="@id/btnBack"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="12dp"/>

    <!-- ═══════════════════════════════════════ -->
    <!-- VIDEO FEED AREA (simulated) -->
    <!-- ═══════════════════════════════════════ -->

    <androidx.cardview.widget.CardView
        android:id="@+id/cardVideoFeed"
        android:layout_width="0dp"
        android:layout_height="210dp"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="#112240"
        app:cardElevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Simulated video feed background -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#0D1B2A"/>

            <!-- Court lines overlay simulation -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LIVE FEED"
                android:textColor="#64FFDA"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_alignParentTop="true"
                android:layout_alignParentStart="true"
                android:layout_margin="10dp"
                android:background="#AA000000"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"/>

            <!-- REC indicator -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⬤ REC"
                android:textColor="#FF4444"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_alignParentTop="true"
                android:layout_alignParentEnd="true"
                android:layout_margin="10dp"/>

            <!-- Center camera icon -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📷"
                android:textSize="40sp"
                android:layout_centerInParent="true"/>

            <!-- AI scanning text -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI SCANNING..."
                android:textColor="#64FFDA"
                android:textSize="12sp"
                android:layout_centerHorizontal="true"
                android:layout_alignParentBottom="true"
                android:layout_marginBottom="10dp"/>

        </RelativeLayout>
    </androidx.cardview.widget.CardView>

    <!-- ═══════════════════════════════════════ -->
    <!-- AI STATUS CARD -->
    <!-- ═══════════════════════════════════════ -->

    <androidx.cardview.widget.CardView
        android:id="@+id/cardStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="#112240"
        app:cardElevation="6dp"
        app:layout_constraintTop_toBottomOf="@id/cardVideoFeed"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI STATUS"
                android:textColor="#64FFDA"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.2"/>

            <TextView
                android:id="@+id/tvAiStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✅ System Active — Monitoring Ball Position"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:layout_marginTop="6dp"/>

            <!-- Progress bar simulating AI activity -->
            <ProgressBar
                android:id="@+id/progressAI"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:progress="72"
                android:progressTint="#64FFDA"
                android:layout_marginTop="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Confidence: 72%"
                android:textColor="#AAAAAA"
                android:textSize="11sp"
                android:layout_marginTop="4dp"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ═══════════════════════════════════════ -->
    <!-- STATS ROW -->
    <!-- ═══════════════════════════════════════ -->

    <LinearLayout
        android:id="@+id/statsRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/cardStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Stat box 1 -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            app:cardCornerRadius="10dp"
            app:cardBackgroundColor="#112240">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="247"
                    android:textColor="#64FFDA"
                    android:textSize="22sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ball Speed"
                    android:textColor="#AAAAAA"
                    android:textSize="11sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="km/h"
                    android:textColor="#AAAAAA"
                    android:textSize="10sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Stat box 2 -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            app:cardCornerRadius="10dp"
            app:cardBackgroundColor="#112240">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="IN"
                    android:textColor="#2ECC71"
                    android:textSize="22sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Last Shot"
                    android:textColor="#AAAAAA"
                    android:textSize="11sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Stat box 3 -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            app:cardCornerRadius="10dp"
            app:cardBackgroundColor="#112240">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="14"
                    android:textColor="#FFD700"
                    android:textSize="22sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="VAR Calls"
                    android:textColor="#AAAAAA"
                    android:textSize="11sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- ═══════════════════════════════════════ -->
    <!-- ACTION BUTTONS ROW -->
    <!-- ═══════════════════════════════════════ -->

    <!-- Call VAR Decision button -->
    <Button
        android:id="@+id/btnVarDecision"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:text="⚖  REQUEST VAR DECISION"
        android:textColor="#0A1628"
        android:textSize="14sp"
        android:textStyle="bold"
        android:backgroundTint="#64FFDA"
        app:layout_constraintTop_toBottomOf="@id/statsRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"/>

    <!-- Open Padel Federation website button (Intent: Open Browser) -->
    <Button
        android:id="@+id/btnOpenWeb"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:text="🌐  Padel Federation Rules"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:background="@drawable/btn_outline_bg"
        app:layout_constraintTop_toBottomOf="@id/btnVarDecision"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="10dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"/>

    <!-- Email Report button (Intent: Send Email) -->
    <Button
        android:id="@+id/btnEmailReport"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:text="📧  Email Match Report"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:background="@drawable/btn_outline_bg"
        app:layout_constraintTop_toBottomOf="@id/btnOpenWeb"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="10dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>