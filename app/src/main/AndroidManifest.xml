<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="Padel VAR"
        android:theme="@style/Theme.AppCompat.Light.NoActionBar">
        <!-- NoActionBar removes the top title bar for a fullscreen look -->

        <!-- MainActivity = the FIRST screen that opens (has LAUNCHER intent) -->
        <activity android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <!-- These two lines together mean: "Open THIS when app icon is tapped" -->
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Register the second screen — no intent-filter needed for non-launcher screens -->
        <activity android:name=".LiveAnalysisActivity"
            android:exported="false" />

        <!-- Register the third screen -->
        <activity android:name=".ReplayActivity"
            android:exported="false" />

    </application>

</manifest>